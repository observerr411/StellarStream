# Soroban RPC endpoint (mainnet or testnet)
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# The deployed StellarStream contract address
CONTRACT_ADDRESS=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Discord webhook URL for the community channel
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Mega Stream threshold in XLM stroops (1 XLM = 10_000_000 stroops)
# Default: 5000 XLM = 50_000_000_000_000 stroops
MEGA_STREAM_THRESHOLD_STROOPS=50000000000000

# How often to poll for new events (milliseconds)
POLL_INTERVAL_MS=5000

# Stellar network passphrase
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
